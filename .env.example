# Astro / MongoDB Atlas configuration

# Puerto local de Astro (opcional)
# ASTRO_PORT=4321

# URI de conexión completa a tu cluster de Mongo Atlas
# Incluye usuario, password y opciones de conexión
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster-url/titienda?retryWrites=true&w=majority

# Nombre de la base de datos donde se guardarán los datos de la tienda
MONGODB_DB_NAME=tiendamix

# Colecciones sugeridas
MONGODB_PRODUCTS_COLLECTION=products
MONGODB_CATEGORIES_COLLECTION=categories
MONGODB_TAGS_COLLECTION=tags

# Si en algún momento necesitas exponer algo al cliente (no recomendado para secretos),
# usa el prefijo PUBLIC_
# PUBLIC_API_BASE=/api
