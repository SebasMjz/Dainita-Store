---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'DainitaStore', description = 'Tu tienda de todo en un solo lugar' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --olive:   #8B7800;
    --yellow:  #E8C110;
    --coral:   #F5365C;
    --crimson: #B71C1C;
    --forest:  #2D7A5A;
    --sage:    #7A9B7A;
    --mint:    #D4F5E0;
    --bg:      #F7F7F5;
    --surface: #FFFFFF;
    --text:    #1A1A1A;
    --muted:   #6B7280;
    --border:  #E5E7EB;
    --radius:  12px;
    --shadow:  0 2px 12px rgba(0,0,0,0.08);
  }

  html, body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100%;
    line-height: 1.5;
  }

  img { display: block; max-width: 100%; }

  button { cursor: pointer; font-family: inherit; border: none; outline: none; }

  input, select, textarea { font-family: inherit; }

  a { text-decoration: none; color: inherit; }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .product-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: #FFF9F0;
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    border: 4px solid var(--card-color);
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.15);
  }



  .card-image-wrap {
    position: relative;
    width: 100%;
    height: 240px; /* Fixed height strictly enforced! No escalonadas */
    background: #ffffff;
    overflow: hidden;
    border-bottom: 2px dashed rgba(0,0,0,0.06);
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s ease;
  }

  .product-card:hover .card-image-wrap img {
    transform: scale(1.08);
  }

  .badge {
    position: absolute;
    top: 15px;
    left: 15px;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    letter-spacing: 0.05em;
    z-index: 5;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
  }

  .card-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-stars {
    color: var(--card-color);
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    margin: 0.5rem 0;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-top: 0.5rem;
    border-top: 2px dashed var(--card-color);
  }

  .card-price {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--card-color);
  }

  .card-add-btn {
    width: 100%;
    padding: 1.1rem;
    text-align: center;
    background: var(--card-color);
    color: #fff;
    font-weight: 800;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: filter 0.2s, background 0.2s;
    border: none;
    cursor: pointer;
  }

  .card-add-btn:hover {
    filter: brightness(1.15);
  }
</style>
